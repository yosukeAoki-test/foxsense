generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String
  name                 String
  role                 String                @default("USER")
  loginAttempts        Int                   @default(0)
  lockedUntil          DateTime?
  twoFactorSecret      String?
  twoFactorEnabled     Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  childDevices         ChildDevice[]
  foxCoinBalance       FoxCoinBalance?
  foxCoinLogs          FoxCoinLog[]
  foxCoinPurchases     FoxCoinPurchase[]
  parentDevices        ParentDevice[]
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  subscription         Subscription?
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ParentDevice {
  id            String             @id @default(uuid())
  userId        String
  deviceId      String             @unique
  deviceSecret  String             @default(uuid())
  name          String
  location      String?
  soracomSimId  String?            @unique
  simStatus     String             @default("INACTIVE")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  alertSettings AlertSettings?
  assignments   DeviceAssignment[]
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sensorData    SensorData[]

  @@index([userId])
}

model ChildDevice {
  id          String             @id @default(uuid())
  userId      String
  deviceId    String             @unique
  name        String
  location    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments DeviceAssignment[]
  sensorData  SensorData[]

  @@index([userId])
}

model DeviceAssignment {
  id            String       @id @default(uuid())
  parentId      String
  childId       String
  logicalId     Int?
  pairingStatus String       @default("PENDING")
  assignedAt    DateTime     @default(now())
  unassignedAt  DateTime?
  child         ChildDevice  @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent        ParentDevice @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([childId])
}

model SensorData {
  id          String        @id @default(uuid())
  parentId    String?
  childId     String?
  deviceType  String
  temperature Float
  humidity    Float
  battery     Float?
  rssi        Int?
  timestamp   DateTime      @default(now())
  child       ChildDevice?  @relation(fields: [childId], references: [id], onDelete: Cascade)
  parent      ParentDevice? @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId, timestamp])
  @@index([childId, timestamp])
}

model FoxCoinPackage {
  id             String            @id @default(uuid())
  name           String
  coins          Int
  price          Int               @default(0)
  stripePriceId  String?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  purchases      FoxCoinPurchase[]
}

model FoxCoinBalance {
  id             String    @id @default(uuid())
  userId         String    @unique
  balance        Int       @default(0)
  simStatus      String    @default("INACTIVE")
  lastDeductedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoxCoinPurchase {
  id               String          @id @default(uuid())
  userId           String
  packageId        String?
  coins            Int
  price            Int
  note             String?
  stripeSessionId  String?         @unique
  activatedAt      DateTime
  purchasedAt      DateTime        @default(now())
  package          FoxCoinPackage? @relation(fields: [packageId], references: [id])
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FoxCoinLog {
  id            String   @id @default(uuid())
  userId        String
  type          String
  coins         Int
  balanceBefore Int
  balanceAfter  Int
  note          String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceInventory {
  id        String    @id @default(uuid())
  deviceId  String    @unique
  type      String    // 'PARENT' or 'CHILD'
  imsi      String?   @unique // SORACOM SIM IMSI（親機のみ）
  claimed   Boolean   @default(false)
  claimedAt DateTime?
  createdAt DateTime  @default(now())
}

model PrintJob {
  id        String   @id @default(cuid())
  text      String
  tapeMm    Int      @default(12)
  status    String   @default("pending")  // pending/printing/done/failed
  error     String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AlertSettings {
  id            String       @id @default(uuid())
  parentId      String       @unique
  tempMin       Float        @default(-5)
  tempMax       Float        @default(40)
  humidityMin   Float        @default(20)
  humidityMax   Float        @default(90)
  frostWarning  Float        @default(3)
  frostCritical Float        @default(0)
  emailEnabled  Boolean      @default(true)
  lineEnabled   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  parent        ParentDevice @relation(fields: [parentId], references: [id], onDelete: Cascade)
}
